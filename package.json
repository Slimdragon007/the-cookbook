    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@playwright/test": "^1.58.2",
